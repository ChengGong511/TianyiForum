<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.tianyi.tianyiforumbackend.Mapper.PortalBoardsMapper">

    <select id="findAll" resultType="com.tianyi.tianyiforumbackend.VO.BoardVO">
        select b.*,u.username as moderator from boards b left join users u on b.moderator_id=u.id
    </select>

</mapper>