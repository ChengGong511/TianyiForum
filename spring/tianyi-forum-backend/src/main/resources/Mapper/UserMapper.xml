<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.tianyi.tianyiforumbackend.Mapper.UserMapper">

    <select id="findALL" resultType="com.tianyi.tianyiforumbackend.VO.UserVO">
        select * from users u
        <where>
            <if test="status!=null and status!='' ">
                and u.status=#{status}
            </if>
            <if test="keyword!=null and keyword!='' ">
                and (u.username like concat('%',#{keyword},'%') or u.email like concat('%',#{keyword},'%'))
            </if>
        </where>

    </select>
    <select id="getByUsername" resultType="com.tianyi.tianyiforumbackend.Eneity.User">
        select * from users where username=#{username}
    </select>
</mapper>